{
  "schema_name": "canonical_trips",
  "version": "1.0",
  "description": "Esquema canónico unificado para viajes de todos los servicios NYC TLC",
  "fields": [
    {"name": "trip_id",               "type": "string",    "nullable": false, "description": "Hash SHA-256 único por viaje"},
    {"name": "service_type",          "type": "string",    "nullable": false, "description": "Tipo de servicio: yellow, green, fhvhv"},
    {"name": "vendor_id",             "type": "string",    "nullable": true,  "description": "Identificador del proveedor/aplicación"},
    {"name": "pickup_datetime",       "type": "timestamp", "nullable": false, "description": "Fecha y hora de inicio del viaje"},
    {"name": "dropoff_datetime",      "type": "timestamp", "nullable": false, "description": "Fecha y hora de fin del viaje"},
    {"name": "passenger_count",       "type": "double",    "nullable": true,  "description": "Número de pasajeros"},
    {"name": "trip_distance",         "type": "double",    "nullable": false, "description": "Distancia del viaje en millas"},
    {"name": "pickup_location_id",    "type": "long",      "nullable": false, "description": "ID de zona de recogida (TLC zones)"},
    {"name": "dropoff_location_id",   "type": "long",      "nullable": false, "description": "ID de zona de destino (TLC zones)"},
    {"name": "rate_code_id",          "type": "double",    "nullable": true,  "description": "Código de tarifa aplicada"},
    {"name": "store_and_fwd_flag",    "type": "string",    "nullable": true,  "description": "Indicador de transmisión diferida"},
    {"name": "payment_type",          "type": "long",      "nullable": true,  "description": "Tipo de pago (1=CC, 2=Cash, etc.)"},
    {"name": "fare_amount",           "type": "double",    "nullable": false, "description": "Tarifa base del viaje"},
    {"name": "extra_amount",          "type": "double",    "nullable": true,  "description": "Recargos adicionales"},
    {"name": "mta_tax",               "type": "double",    "nullable": true,  "description": "Impuesto MTA"},
    {"name": "tip_amount",            "type": "double",    "nullable": true,  "description": "Propina"},
    {"name": "tolls_amount",          "type": "double",    "nullable": true,  "description": "Peajes"},
    {"name": "improvement_surcharge", "type": "double",    "nullable": true,  "description": "Recargo de mejora"},
    {"name": "total_amount",          "type": "double",    "nullable": false, "description": "Total pagado"},
    {"name": "congestion_surcharge",  "type": "double",    "nullable": true,  "description": "Recargo por congestión"},
    {"name": "airport_fee",           "type": "double",    "nullable": true,  "description": "Tarifa de aeropuerto"},
    {"name": "ehail_fee",             "type": "double",    "nullable": true,  "description": "Cargo e-hail (solo green)"},
    {"name": "trip_type",             "type": "double",    "nullable": true,  "description": "Tipo de viaje (solo green)"},
    {"name": "year",                  "type": "integer",   "nullable": false, "description": "Año del viaje (partición)"},
    {"name": "month",                 "type": "integer",   "nullable": false, "description": "Mes del viaje (partición)"},
    {"name": "source_file",           "type": "string",    "nullable": false, "description": "Archivo Parquet de origen"},
    {"name": "ingestion_timestamp",   "type": "timestamp", "nullable": false, "description": "Timestamp de ingesta en el pipeline"},
    {"name": "quality_status",        "type": "string",    "nullable": false, "description": "Estado de calidad: VALID, SUSPICIOUS, REJECTED"}
  ]
}
